# =============================================================================
# LLM4Writing — Environment Variable Reference
# Copy this file to .env.local (development) or set vars in your hosting panel.
# NEVER commit real secrets to source control.
# =============================================================================

# -----------------------------------------------------------------------------
# [REQUIRED in production] Authentication session signing secret
# Must be a long, random, unpredictable string (32+ chars recommended).
# Generate with: node -e "console.log(require('crypto').randomBytes(40).toString('hex'))"
# If unset in production the server will throw "auth_secret_missing" on startup.
# -----------------------------------------------------------------------------
AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# -----------------------------------------------------------------------------
# [REQUIRED in production for research export] Student hash salt
# Used to derive activity-scoped studentHash values in research JSON exports.
# Must be random, secret, and deployment-specific. If unset in production,
# /api/teacher/research-export fails closed with research_export_hash_salt_missing.
# Generate with: node -e "console.log(require('crypto').randomBytes(40).toString('hex'))"
# -----------------------------------------------------------------------------
RESEARCH_EXPORT_HASH_SALT=replace-with-a-long-random-secret-for-research-export

# -----------------------------------------------------------------------------
# [REQUIRED in production] Database
# Supabase database URL is preferred. Use the Transaction Pooler URL (:6543)
# for Vercel serverless deployments to avoid connection exhaustion.
# -----------------------------------------------------------------------------
SUPABASE_DB_URL=postgres://postgres:password@db.<project-ref>.supabase.co:6543/postgres

# -----------------------------------------------------------------------------
# [RECOMMENDED] Canonical app origin for CSRF origin checks
# Example: https://llm4writing.example.com
# If set, proxy.ts will use this as the expected origin baseline for mutating
# /api/admin/*, /api/teacher/*, /api/session/* requests.
# -----------------------------------------------------------------------------
# APP_ORIGIN=https://your-domain.example.com

# -----------------------------------------------------------------------------
# [OPTIONAL INCIDENT SWITCH] Disable nonce CSP injection in proxy
# Set to 1 only for emergency mitigation when proxy nonce/CSP path causes
# runtime instability on specific edge/runtime environments.
# -----------------------------------------------------------------------------
# PROXY_DISABLE_NONCE_CSP=1

# -----------------------------------------------------------------------------
# [RECOMMENDED in multi-replica production] Upstash Redis
# Used for cross-replica API rate limiting, login lockout, and presence.
# If omitted, login lockout falls back to process memory so existing deployments
# can still authenticate; this is single-replica only and less strict.
# Set REQUIRE_DISTRIBUTED_LOGIN_RATE_LIMIT=1 only when Upstash is configured and
# you want login to fail closed if Redis is unavailable.
# -----------------------------------------------------------------------------
# UPSTASH_REDIS_REST_URL=https://...
# UPSTASH_REDIS_REST_TOKEN=...
# REQUIRE_DISTRIBUTED_LOGIN_RATE_LIMIT=1

# Optional: force pool mode detection override.
# Set to "transaction" if using Supabase transaction pooler (:6543).
# Set to "session"     if using a session pooler or direct connection.
# If omitted, code auto-detects from URL.
# SUPABASE_POOL_MODE=transaction

# Legacy fallbacks (kept for backward compatibility only).
# POSTGRES_URL=postgres://user:password@host:5432/dbname
# DATABASE_URL=postgres://user:password@host:5432/dbname

# -----------------------------------------------------------------------------
# [OPTIONAL] Remote LLM (provider-agnostic, OpenAI-compatible)
# If all three are set, the server will call the remote LLM for AI responses.
# Example using OpenRouter:
# -----------------------------------------------------------------------------
# LLM_URL=https://openrouter.ai/api/v1/chat/completions
# LLM_MODEL=google/gemma-2-9b-it:free
# LLM_KEY=sk-or-v1-...

# -----------------------------------------------------------------------------
# Security notes (#383, #384, M2, L3)
# -----------------------------------------------------------------------------
# 1. AUTH_SECRET must be rotated if it is ever exposed. Rotating it invalidates
#    all existing sessions (users will need to log in again).
# 2. Default demo accounts (admin/admin123, teacher/teacher123, student/student123)
#    are seeded automatically in development mode. DELETE these accounts before
#    going live — or ensure NODE_ENV=production so they are not seeded.
# 3. Ensure your database uses Row-Level Security (RLS) if using Supabase.
#    Run scripts/supabase/harden_security.sh if Supabase Advisor flags issues.
