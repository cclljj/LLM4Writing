# Supabase database URL (preferred).
SUPABASE_DB_URL=postgres://postgres:password@db.<project-ref>.supabase.co:5432/postgres

# Legacy fallbacks (kept for backward compatibility only).
# POSTGRES_URL=postgres://user:password@host:5432/dbname
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Remote LLM (provider-agnostic). If all are set, server will call the remote LLM.
# Example (OpenRouter OpenAI-compatible endpoint):
# LLM_URL=https://openrouter.ai/api/v1/chat/completions
# LLM_MODEL=google/gemma-2-9b-it:free
# LLM_KEY=sk-...
